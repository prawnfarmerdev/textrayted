# Windows cross-compilation with mingw-w64 (release)
CC = x86_64-w64-mingw32-gcc
CFLAGS = -Wall -O2 -std=c11 -mwindows -Iwinlibs/raylib-5.5_win64_mingw-w64/include
LDFLAGS = -Lwinlibs/raylib-5.5_win64_mingw-w64/lib -static -static-libgcc
LIBS = -lraylib -lwinmm -lgdi32 -lshell32 -lopengl32
TARGET = textrayted.exe
SOURCES = main.c

all: $(TARGET)

$(TARGET): $(SOURCES)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $(TARGET) $(SOURCES) $(LIBS)

clean:
	rm -f $(TARGET) *.o

.PHONY: all clean